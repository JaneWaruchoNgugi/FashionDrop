rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function hasAdminDoc() { return exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function hasUpperUserAdminDoc() {
      return exists(/databases/$(database)/documents/Users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.Role == 'admin' ||
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.email == request.auth.token.email
      );
    }
    function hasLowerUserAdminDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.Role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == request.auth.token.email
      );
    }
    function isAdmin() { return signedIn() && (hasAdminDoc() || hasUpperUserAdminDoc() || hasLowerUserAdminDoc()); }
    function isBuyerOwner() { return signedIn() && resource.data.buyerId == request.auth.uid; }
    function createsOwnOrder() { return signedIn() && request.resource.data.buyerId == request.auth.uid; }
    function isTrackableOrder() {
      return resource.data.status in ['pending_payment', 'paid', 'out_for_delivery', 'delivered'];
    }

    // Admins can list all admin docs and add/remove other admins.
    match /admins/{adminId} {
      allow read: if signedIn() && (request.auth.uid == adminId || isAdmin());
      allow create, delete: if isAdmin();
      allow update: if false;
    }
    match /Users/{userId} { allow read: if signedIn() && request.auth.uid == userId; allow write: if false; }
    match /users/{userId} { allow read: if signedIn() && request.auth.uid == userId; allow write: if false; }
    match /buyers/{buyerId} {
      allow read, update: if isAdmin() || (signedIn() && request.auth.uid == buyerId);
      allow create: if signedIn() && request.auth.uid == buyerId;
      allow delete: if isAdmin();
    }
    match /categories/{categoryId} { allow read: if true; allow write: if isAdmin(); }
    match /products/{productId} { allow read: if true; allow write: if isAdmin(); }
    match /riders/{riderId} { allow read, create: if true; allow update: if true; allow delete: if isAdmin(); }
    match /orders/{orderId} {
      allow read: if isAdmin() || isBuyerOwner() || isTrackableOrder();
      allow create: if createsOwnOrder();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
