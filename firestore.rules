rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function hasAdminDoc() { return exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function hasUpperUserAdminDoc() {
      return exists(/databases/$(database)/documents/Users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.Role == 'admin' ||
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.email == request.auth.token.email
      );
    }
    function hasLowerUserAdminDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.Role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email == request.auth.token.email
      );
    }
    function isAdmin() { return signedIn() && (hasAdminDoc() || hasUpperUserAdminDoc() || hasLowerUserAdminDoc()); }
    function riderSafeOrderUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'riderId', 'riderName', 'status', 'updatedAt', 'statusHistory'
      ]);
    }

    match /admins/{adminId} { allow read: if signedIn() && request.auth.uid == adminId; allow write: if false; }
    match /Users/{userId} { allow read: if signedIn() && request.auth.uid == userId; allow write: if false; }
    match /users/{userId} { allow read: if signedIn() && request.auth.uid == userId; allow write: if false; }
    match /products/{productId} { allow read: if true; allow write: if isAdmin(); }
    match /riders/{riderId} { allow read, create: if true; allow update: if true; allow delete: if isAdmin(); }
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin() || riderSafeOrderUpdate();
      allow delete: if false;
    }
  }
}
